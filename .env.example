# Moteur IA à utiliser : "anthropic" ou "gemini".
# Si omis, "gemini" est utilisé automatiquement dès que GEMINI_API_KEY est renseignée.
AI_PROVIDER=gemini

# --- Option A (gratuite pour tester) : Google Gemini ---
# Clé API gratuite (sans carte bancaire) sur https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optionnel : modèle Gemini à utiliser (par défaut: gemini-flash-latest)
GEMINI_MODEL=gemini-flash-latest

# --- Option B (payante) : Anthropic Claude ---
# Clé API sur https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optionnel : modèle Claude à utiliser (par défaut: claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5

# --- Optionnel : banque d'images libres de droits (slides "Icône + texte") ---
# Fournisseur à utiliser : "unsplash" ou "pexels". Si omis, déduit de la clé renseignée.
IMAGE_PROVIDER=
# Clé gratuite sur https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
# Ou clé gratuite sur https://www.pexels.com/api/
PEXELS_API_KEY=
